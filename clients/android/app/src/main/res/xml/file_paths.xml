<?xml version="1.0" encoding="utf-8"?>
<!--
  FileProvider roots for ClipBridge.

  Keep exposed roots narrow: cached image/share payloads, staged outbound
  file copies, and the app-scoped ClipBridge download folder used by LAN
  file receive.
-->
<paths>
    <cache-path name="clipbridge_images" path="clipbridge_images/" />
    <cache-path name="clipbridge_file_sends" path="clipbridge_file_sends/" />
    <files-path name="clipbridge_internal_downloads" path="ClipBridge/" />
    <external-files-path name="clipbridge_downloads" path="Download/ClipBridge/" />
</paths>
