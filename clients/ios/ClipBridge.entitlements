<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- 允许后台 socket。普通 App 默认就有,显式列出更稳。 -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- iOS 16+ 默认每次粘贴弹"已粘贴自 ClipBridge"提示,这条把它静音。
         TrollStore 能签上这个私有 key,普通侧载不行。 -->
    <key>com.apple.UIKit.allow-paste-without-prompt</key>
    <true/>
</dict>
</plist>
