{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Frontend permissions for the ClipBridge pairing window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open"
  ]
}
