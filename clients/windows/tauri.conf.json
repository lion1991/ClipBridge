{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClipBridge",
  "version": "0.1.0",
  "identifier": "com.clipbridge.windows",
  "build": {
    "frontendDist": "./ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ClipBridge",
        "width": 480,
        "height": 640,
        "minWidth": 420,
        "minHeight": 540,
        "resizable": true,
        "visible": false,
        "decorations": true,
        "transparent": false,
        "center": true,
        "skipTaskbar": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Cross-device clipboard sync",
    "longDescription": "ClipBridge syncs your clipboard between macOS, Windows, and Android via an end-to-end encrypted relay."
  }
}
